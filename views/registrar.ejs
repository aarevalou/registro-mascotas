<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
  <title>Registrar mascota</title>
</head>
<body>
  <%- include('partials/navbar', { activo }) %>

  <div class="container pb-5" style="max-width: 860px;">
    <div id="alertContainer"></div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h1 class="h5 mb-4">Registrar nueva mascota</h1>
        <form id="formMascota" class="row g-3">
          <div class="col-sm-6">
            <label for="nombre" class="form-label small">Nombre</label>
            <input
              type="text"
              class="form-control"
              id="nombre"
              name="nombre"
              placeholder="Ej: Firulais"
              required
            />
          </div>
          <div class="col-sm-6">
            <label for="rut" class="form-label small">Rut del dueño</label>
            <input
              type="text"
              class="form-control"
              id="rut"
              name="rut"
              placeholder="Ej: 12.345.678-9"
              required
            />
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-dark">Registrar</button>
            <a href="/mascotas" class="btn btn-outline-dark me-2">Ver listado</a>
          </div>
        </form>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios@1.7.2/dist/axios.min.js"></script>
  <script src="/js/registrar.js"></script>
</body>
</html>
